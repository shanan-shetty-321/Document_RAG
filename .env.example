# Copy this file to ".env" and fill in your key. The .env file is gitignored.

# Groq API key (free, no credit card) — create one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional overrides (defaults shown)
LLM_MODEL=llama-3.3-70b-versatile
API_URL=http://localhost:8000
